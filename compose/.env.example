# DNS Homelab — Pi-hole Configuration
# Lokal auf jeder VM nach .env kopieren, NIE ins Repo committen!

# ── General ──
TZ=Europe/Berlin

# Hostname (dns1 oder dns2). Wird automatisch von bootstrap.sh gesetzt.
DNS_HOSTNAME=dns1

# ── Pi-hole Authentication ──
# Web-Admin-Passwort (im Passwort-Manager speichern)
FTLCONF_webserver_api_password=CHANGE_ME

# ── Network ──
# Statische IP dieser VM
FTLCONF_LOCAL_IPV4=192.168.1.10

# ── DNS Upstreams ──
# Cloudflare + Quad9, parallel
FTLCONF_dns_upstreams=1.1.1.1;1.0.0.1;9.9.9.9;149.112.112.112

# ── DNSSEC ──
FTLCONF_dns_dnssec=true

# ── Reverse DNS / Conditional Forwarding (optional) ──
# Format: enabled,router-ip/cidr,domain
# Beispiel UDM bei 192.168.1.1, lokale Domain "lan":
# FTLCONF_dns_revServers=true,192.168.1.1/24,lan
FTLCONF_dns_revServers=
