# Pi-hole Homelab DNS Configuration
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git!

# ---- General ----
# Timezone (IANA format)
TZ=Europe/Berlin

# Hostname for Pi-hole container (pihole-a or pihole-b)
PIHOLE_HOSTNAME=pihole-a

# ---- Pi-hole Authentication ----
# Web admin password. Use a strong password and store it in your password manager.
FTLCONF_webserver_api_password=CHANGE_ME

# ---- Network ----
# Static IP of this VM (must match the IP configured via systemd-networkd)
FTLCONF_LOCAL_IPV4=192.168.1.10

# ---- DNS Upstreams ----
# Cloudflare + Quad9, semicolon-separated
FTLCONF_dns_upstreams=1.1.1.1;1.0.0.1;9.9.9.9;149.112.112.112

# ---- DNSSEC ----
FTLCONF_dns_dnssec=true

# ---- Reverse DNS / Conditional Forwarding (optional) ----
# Format: enabled,router-ip,cidr,domain
# Example for UDM at 192.168.1.1 with local domain "lan":
# FTLCONF_dns_revServers=true,192.168.1.1/24,lan
FTLCONF_dns_revServers=
